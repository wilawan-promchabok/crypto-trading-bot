# ── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id
GUILD_ID=your_server_guild_id

# ── Alert channel ─────────────────────────────────────────
# ID ของ channel ที่ bot จะส่งแจ้งเตือนสัญญาณอัตโนมัติ
ALERT_CHANNEL_ID=your_channel_id_here

# ── Watchlist เริ่มต้น (คั่นด้วย ,) ──────────────────────
DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# ── Cron schedule (default: ทุก 5 นาที) ──────────────────
# ดู syntax ที่ https://crontab.guru
ALERT_INTERVAL_CRON=*/5 * * * *
